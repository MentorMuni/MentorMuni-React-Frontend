# Resume Analyzer Frontend Configuration
# Copy this file to .env.local and update values as needed

# Backend API URL (optional; default is production Railway backend)
# Omit to use: https://mentormuni-python-backend-production.up.railway.app
# For local development, set:
# VITE_API_URL=http://localhost:5000

# Feature flags
VITE_ENABLE_RESUME_ANALYZER=true

# File upload settings
VITE_MAX_FILE_SIZE_MB=5
