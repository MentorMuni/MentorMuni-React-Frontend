# Resume Analyzer Frontend Configuration
# Copy this file to .env.local and update values as needed

# Backend API URL (use VITE_ prefix for Vite projects)
# For local development:
VITE_API_URL=http://localhost:5000
# For production (set this before running npm run deploy):
# VITE_API_URL=https://your-backend.up.railway.app

# Feature flags
VITE_ENABLE_RESUME_ANALYZER=true

# File upload settings
VITE_MAX_FILE_SIZE_MB=5
